{
  "name": "jarvus",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Jarvis: a desktop AI agent with an animated face, local voice, and Claude as the brain.",
  "scripts": {
    "install:all": "npm --prefix proxy install && npm --prefix frontend install",
    "proxy": "npm --prefix proxy run dev",
    "proxy:test": "npm --prefix proxy test",
    "frontend": "npm --prefix frontend run dev:all",
    "tunnel": "node scripts/tunnel.mjs",
    "tunnel:docker": "docker compose up --build",
    "dev": "npm --prefix frontend run dev",
    "dev:all": "npm --prefix frontend run dev:all",
    "build": "npm --prefix frontend run build",
    "tauri:dev": "npm --prefix frontend run tauri:dev",
    "tauri:build": "npm --prefix frontend run tauri:build"
  }
}
