<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Required so macOS will prompt for and allow camera/microphone access
         inside the WKWebView (the Tavus WebRTC video call). Tauri merges this
         into the generated app Info.plist. -->
    <key>NSCameraUsageDescription</key>
    <string>Jarvus uses your camera for the live video conversation with the agent.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Jarvus uses your microphone so you can talk to the agent and to listen for the "Hey Jarvus" wake word.</string>
    <!-- Keep the microphone available while backgrounded so the "Hey Jarvus" wake
         word keeps listening. The app stays in the menu bar (not a hidden agent). -->
    <key>UIBackgroundModes</key>
    <array>
        <string>audio</string>
    </array>
    <key>LSBackgroundOnly</key>
    <false/>
</dict>
</plist>
