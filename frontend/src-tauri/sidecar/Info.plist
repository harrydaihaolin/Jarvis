<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Embedded into the sidecar binaries (__TEXT,__info_plist) by
         scripts/build-sidecar.sh. Unbundled binaries have no Info.plist, and
         macOS TCC SIGABRTs any process that touches privacy-sensitive APIs
         (speech recognition / microphone / camera) without these keys. -->
    <key>CFBundleIdentifier</key>
    <string>com.jarvus.sidecar</string>
    <key>CFBundleName</key>
    <string>Jarvis Sidecar</string>
    <key>NSSpeechRecognitionUsageDescription</key>
    <string>Jarvis transcribes your speech so you can talk to it instead of typing.</string>
    <key>NSMicrophoneUsageDescription</key>
    <string>Jarvis listens for the "Hey Jarvis" wake phrase and your voice commands.</string>
    <key>NSCameraUsageDescription</key>
    <string>Jarvis uses the camera for eye tracking so its eyes can follow you.</string>
</dict>
</plist>
