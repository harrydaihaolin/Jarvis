# Jarvis — environment configuration.
# Copy to `.env` and fill in. The proxy and the Tauri desktop app read what they
# need from this single file.

# ── Anthropic (Claude — the agent's brain) ───────────────────────────────────
ANTHROPIC_API_KEY=
# Haiku 4.5 = fastest turns (best for live voice); Sonnet 4.6 / Opus 4.8 = smarter.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_MAX_TOKENS=1024

# ── Proxy (OpenAI-compatible Claude bridge the desktop app calls) ─────────────
PROXY_PORT=8787
# Shared secret between the app and the proxy (any random string).
PROXY_API_KEY=
PROXY_ALLOW_UNAUTHENTICATED=false

# ── Agent capabilities ────────────────────────────────────────────────────────
AGENT_ENABLE_WEB_SEARCH=true
WEB_SEARCH_MAX_USES=5
AGENT_ENABLE_COMMANDS=false
AGENT_MAX_TOOL_ITERATIONS=8
AGENT_WORKSPACE=./workspace
AGENT_ENABLE_MEMORY=true
JARVIS_MEMORY_STORE_NAME=jarvis-memory
JARVIS_MEMORY_STORE_ID=

# ── Fireworks AI (primary LLM; falls back to Claude if unset or on error) ────
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/kimi-k2p5
FIREWORKS_FALLBACK_ENABLED=true
# Small fast model for the spoken preamble ("On it." in well under a second).
# Set JARVUS_PREAMBLE_ENABLED=false to disable. Auto-disabled if FIREWORKS_API_KEY is unset.
FIREWORKS_PREAMBLE_MODEL=accounts/fireworks/models/gpt-oss-120b
JARVUS_PREAMBLE_ENABLED=true

# ── Notion notes (MCP) ────────────────────────────────────────────────────────
NOTION_TOKEN=
NOTION_DATABASE_ID=

# ── "Hey Jarvus" wake word (Tauri desktop app) ────────────────────────────────
# Picovoice Porcupine AccessKey (free tier: https://console.picovoice.ai).
PICOVOICE_ACCESS_KEY=

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# The desktop app calls the local proxy directly.
VITE_PROXY_URL=http://localhost:8787
# Must match PROXY_API_KEY above (unless PROXY_ALLOW_UNAUTHENTICATED=true).
VITE_PROXY_API_KEY=
# Local Kokoro neural-TTS server (run ./tts/start.sh). Falls back to system voice.
VITE_TTS_URL=http://localhost:8788
# Voice-pipeline diagnostics in the dev console (barge-in/finals). 0 to silence.
VITE_DIAGNOSTICS=1
