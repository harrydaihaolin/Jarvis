# Jarvus — environment configuration.
# Copy to `.env` and fill in. The proxy, setup script, frontend backend, and the
# Tauri desktop app all read the variables they need from this single file.

# ── Anthropic (Claude — the agent's brain) ───────────────────────────────────
ANTHROPIC_API_KEY=
# Model Tavus's persona reports / the proxy uses. Opus 4.7 gives the best results;
# Sonnet 4.6 is snappier for low-latency turns.
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024

# ── Tavus (the video replica + conversation) ─────────────────────────────────
TAVUS_API_KEY=
# A MALE Phoenix stock replica for "Jarvus". Pick one from
#   GET https://tavusapi.com/v2/replicas?replica_type=system
# (it's environment-specific, so it isn't hardcoded here).
TAVUS_REPLICA_ID=
# Optional: reuse an existing persona instead of creating one.
TAVUS_PERSONA_ID=
# Keep test mode on while developing — no Tavus minutes are billed.
TAVUS_TEST_MODE=true

# Persona identity.
PERSONA_NAME=Jarvus
PERSONA_SYSTEM_PROMPT=
PERSONA_GREETING=

# ── Proxy (OpenAI-compatible Claude bridge that Tavus calls) ──────────────────
PROXY_PORT=8787
# Shared secret between Tavus and the proxy (any random string).
PROXY_API_KEY=
PROXY_ALLOW_UNAUTHENTICATED=false
# Public HTTPS URL Tavus uses to reach the proxy, ending in /v1
# (auto-detected from a running ngrok/cloudflared tunnel if left blank).
PUBLIC_PROXY_BASE_URL=

# ── Agent capabilities ────────────────────────────────────────────────────────
AGENT_ENABLE_WEB_SEARCH=true
WEB_SEARCH_MAX_USES=5
AGENT_ENABLE_COMMANDS=false
AGENT_MAX_TOOL_ITERATIONS=8
AGENT_WORKSPACE=./workspace
AGENT_ENABLE_MEMORY=true
JARVIS_MEMORY_STORE_NAME=jarvis-memory
JARVIS_MEMORY_STORE_ID=

# ── Notion notes (MCP) ────────────────────────────────────────────────────────
# Notion integration token (https://www.notion.so/my-integrations).
NOTION_TOKEN=
# ID of the "Jarvus Notes" database (lives under your "Jarvus" Notion page).
NOTION_DATABASE_ID=

# ── "Hey Jarvus" wake word + session sleep (Tauri desktop app) ────────────────
# Picovoice Porcupine AccessKey (free tier: https://console.picovoice.ai).
PICOVOICE_ACCESS_KEY=
# Seconds of silence before the desktop app ends the session (default 5 min).
JARVUS_IDLE_TIMEOUT_SECS=300

# ── Option A: Tavus-hosted Claude (no proxy; chat only, no agent tools) ───────
USE_TAVUS_HOSTED_LLM=false
TAVUS_HOSTED_MODEL=tavus-claude-haiku-4.5

# ── Tunnel (Option B) ─────────────────────────────────────────────────────────
NGROK_AUTHTOKEN=

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Point the Agent Console at a non-default proxy if needed.
VITE_PROXY_URL=http://localhost:8787
