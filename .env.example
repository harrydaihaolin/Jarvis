# Jarvis — environment configuration.
# Copy to `.env` and fill in. The proxy and the Tauri desktop app read what they
# need from this single file.

# ── Anthropic (Claude — the agent's brain) ───────────────────────────────────
ANTHROPIC_API_KEY=
# Opus 4.8 gives the best results; Sonnet 4.6 is snappier for low-latency turns.
ANTHROPIC_MODEL=claude-sonnet-4-6
ANTHROPIC_MAX_TOKENS=1024

# ── Proxy (OpenAI-compatible Claude bridge the desktop app calls) ─────────────
PROXY_PORT=8787
# Shared secret between the app and the proxy (any random string).
PROXY_API_KEY=
PROXY_ALLOW_UNAUTHENTICATED=false

# ── Agent capabilities ────────────────────────────────────────────────────────
AGENT_ENABLE_WEB_SEARCH=true
WEB_SEARCH_MAX_USES=5
AGENT_ENABLE_COMMANDS=false
AGENT_MAX_TOOL_ITERATIONS=8
AGENT_WORKSPACE=./workspace
AGENT_ENABLE_MEMORY=true
JARVIS_MEMORY_STORE_NAME=jarvis-memory
JARVIS_MEMORY_STORE_ID=

# ── Notion notes (MCP) ────────────────────────────────────────────────────────
NOTION_TOKEN=
NOTION_DATABASE_ID=

# ── "Hey Jarvus" wake word (Tauri desktop app) ────────────────────────────────
# Picovoice Porcupine AccessKey (free tier: https://console.picovoice.ai).
PICOVOICE_ACCESS_KEY=

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# The desktop app calls the local proxy directly.
VITE_PROXY_URL=http://localhost:8787
# Must match PROXY_API_KEY above (unless PROXY_ALLOW_UNAUTHENTICATED=true).
VITE_PROXY_API_KEY=
